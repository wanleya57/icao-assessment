.record-page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }

.status-bar { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; background: #fff; border-bottom: 1rpx solid #eee; }
.status-left { display: flex; flex-direction: column; }
.student-name { font-size: 32rpx; font-weight: 600; color: #111; }
.total-count { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.end-btn { background: #e53935; color: #fff; padding: 12rpx 28rpx; border-radius: 8rpx; font-size: 26rpx; }

.comp-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; padding: 24rpx; }
.comp-card { background: #fff; border-radius: 16rpx; padding: 24rpx 12rpx; display: flex; flex-direction: column; align-items: center; border: 2rpx solid #eee; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); transition: all 0.15s; }
.comp-card:active { transform: scale(0.95); }
.comp-icon { font-size: 48rpx; margin-bottom: 8rpx; }
.comp-name { font-size: 22rpx; color: #555; text-align: center; font-weight: 500; }

.comp-level-badge { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx; margin-top: 6rpx; font-weight: 500; }
.comp-level-badge.level-1 { background: #ffebee; color: #e53935; }
.comp-level-badge.level-2 { background: #ffebee; color: #e53935; }
.comp-level-badge.level-3 { background: #e8f5e9; color: #2e7d32; }
.comp-level-badge.level-4 { background: #e3f2fd; color: #1565c0; }
.comp-level-badge.level-unrated { background: #f5f5f5; color: #bbb; }

.comp-stat { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.assess-progress { margin: 0 24rpx 20rpx; padding: 20rpx 24rpx; background: #fff; border-radius: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.progress-text { font-size: 24rpx; color: #666; margin-bottom: 8rpx; display: block; }
.progress-bar-bg { height: 12rpx; background: #f0f0f0; border-radius: 6rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; background: #1a73e8; border-radius: 6rpx; transition: width 0.3s; }

.end-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 99; }
.end-popup { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 40rpx 32rpx; z-index: 100; transform: translateY(100%); transition: transform 0.3s; }
.end-popup.show { transform: translateY(0); }
.end-popup-title { font-size: 34rpx; font-weight: 600; color: #111; text-align: center; margin-bottom: 12rpx; }
.end-popup-desc { font-size: 26rpx; color: #999; text-align: center; margin-bottom: 32rpx; }
.end-popup-actions { display: flex; gap: 20rpx; }

/* AI 评语识别 */
.ai-section { margin: 0 24rpx 20rpx; padding: 24rpx; background: #fff; border-radius: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.ai-section-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; }
.ai-input { width: 100%; min-height: 120rpx; background: #f9f9f9; border: 1rpx solid #eee; border-radius: 12rpx; padding: 16rpx; font-size: 26rpx; color: #333; box-sizing: border-box; margin-bottom: 16rpx; }
.ai-btn { display: flex; align-items: center; justify-content: center; gap: 12rpx; padding: 20rpx; background: #111; border-radius: 12rpx; }
.ai-btn.loading { opacity: 0.6; }
.ai-spinner { width: 28rpx; height: 28rpx; border: 3rpx solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.ai-btn text { font-size: 28rpx; font-weight: 500; color: #fff; }

/* AI 结果 */
.ai-results { margin: 0 24rpx 20rpx; background: #fff; border-radius: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); overflow: hidden; }
.ai-results-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.ai-results-title { font-size: 28rpx; font-weight: 600; color: #333; }
.ai-results-close { font-size: 32rpx; color: #999; padding: 8rpx; }

.ai-result-item { padding: 20rpx 24rpx; border-bottom: 1rpx solid #f5f5f5; }
.ai-result-item:last-child { border-bottom: none; }

.ai-checkbox { width: 40rpx; height: 40rpx; border-radius: 50%; border: 3rpx solid #ccc; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.15s; }
.ai-checkbox.checked { background: #4caf50; border-color: #4caf50; }
.ai-checkbox-icon { font-size: 24rpx; color: #fff; font-weight: 700; }
.ai-result-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.ai-result-ob { font-size: 26rpx; font-weight: 600; color: #1a73e8; flex: 1; }
.ai-result-level { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx; }
.ai-result-level.level-1 { background: #ffebee; color: #e53935; }
.ai-result-level.level-2 { background: #ffebee; color: #e53935; }
.ai-result-level.level-3 { background: #e8f5e9; color: #2e7d32; }
.ai-result-level.level-4 { background: #e3f2fd; color: #1565c0; }

.ai-fb-row { display: flex; align-items: flex-start; gap: 12rpx; margin-top: 8rpx; }
.ai-fb-label { font-size: 22rpx; color: #999; flex-shrink: 0; padding-top: 2rpx; }
.ai-fb-text { font-size: 24rpx; color: #666; line-height: 1.5; }
.ai-fb-text.professional { color: #333; }
.ai-apply-all { text-align: center; padding: 20rpx; font-size: 28rpx; font-weight: 500; color: #1a73e8; border-top: 1rpx solid #f0f0f0; }
