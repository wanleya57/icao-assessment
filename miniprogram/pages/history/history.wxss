.history-page { padding: 24rpx; min-height: 100vh; box-sizing: border-box; }
.page-header { margin-bottom: 24rpx; }
.page-title { font-size: 36rpx; font-weight: 700; color: #111; }

.filter-bar { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.filter-item { padding: 12rpx 28rpx; border-radius: 8rpx; font-size: 26rpx; background: #f0f0f0; color: #666; }
.filter-item.active { background: #111; color: #fff; }

.session-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.session-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.session-name { font-size: 30rpx; font-weight: 600; color: #111; }
.session-status { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 4rpx; }
.session-status.in_progress { background: #e3f2fd; color: #1565c0; }
.session-status.completed { background: #e8f5e9; color: #2e7d32; }
.session-info { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }
.session-bottom { display: flex; justify-content: space-between; align-items: center; }
.session-date { font-size: 22rpx; color: #bbb; }
.session-del { font-size: 24rpx; color: #e53935; padding: 8rpx 0; }

.empty { display: flex; flex-direction: column; align-items: center; padding: 160rpx 0; }
.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #ccc; }
