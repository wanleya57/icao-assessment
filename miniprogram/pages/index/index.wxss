.home-page { padding: 24rpx; min-height: 100vh; box-sizing: border-box; }
.header { padding: 40rpx 0 32rpx; }
.header-title { font-size: 44rpx; font-weight: 700; color: #111; display: block; }
.header-sub { font-size: 24rpx; color: #999; margin-top: 4rpx; }

.card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.card-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }

.recent-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.recent-item:last-child { border-bottom: none; }
.recent-left { display: flex; flex-direction: column; }
.recent-name { font-size: 28rpx; font-weight: 500; color: #333; }
.recent-info { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.recent-arrow { font-size: 26rpx; color: #1a73e8; }

.form-item { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 8rpx; display: block; }
.form-input { background: #f5f5f5; border: 1rpx solid #e8e8e8; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; height: 88rpx; line-height: 48rpx; }
.picker-display { display: flex; justify-content: space-between; align-items: center; }
.picker-arrow { font-size: 32rpx; color: #ccc; }

.pilot-chips { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 20rpx; }
.pilot-chip-wrap { display: flex; align-items: center; background: #f0f0f0; border-radius: 8rpx; overflow: hidden; }
.pilot-chip-wrap.active { background: #111; color: #fff; }
.pilot-chip { padding: 10rpx 24rpx; font-size: 24rpx; color: #666; }
.pilot-chip-wrap.active .pilot-chip { color: #fff; }
.pilot-chip-del { padding: 10rpx 12rpx 10rpx 0; font-size: 20rpx; color: #999; line-height: 1; }
.pilot-chip-wrap.active .pilot-chip-del { color: rgba(255,255,255,0.5); }
.pilot-chip.add { background: #f9f9f9; color: #999; border: 1rpx dashed #ccc; padding: 10rpx 24rpx; border-radius: 8rpx; }

.add-pilot-row { display: flex; gap: 12rpx; align-items: center; margin-bottom: 20rpx; }
.start-btn { margin-top: 16rpx; }
