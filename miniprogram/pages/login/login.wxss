page {
  background: #00104A;
  height: 100%;
  overflow: hidden;
  margin: 0;
  padding: 0;
}

.page {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #00104A;
}

.page::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 8, 40, 0.1);
  z-index: 1;
}

.bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

/* 卡片 */
.card {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: 150rpx;
  width: 595rpx;
  background: linear-gradient(
    180deg,
    #001758 0%,
    #001248 45%,
    #000E3C 100%
  );
  border: 1rpx solid rgba(120, 150, 255, 0.06);
  border-bottom: none;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.02);
  border-radius: 40rpx;
  padding: 130rpx 28rpx 41rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  position: relative;
  top: -60rpx;
  margin-bottom: 24rpx;
}

/* 输入框 */
.field {
  display: flex;
  align-items: center;
  height: 84rpx;
  background: rgba(70, 110, 210, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 10rpx;
  padding: 0 18rpx;
  margin-bottom: 14rpx;
  transition: all 0.2s;
}

.on {
  border-color: rgba(30, 110, 255, 0.5);
  background: rgba(70, 110, 210, 0.32);
}

.ic-u {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #fff;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
  position: relative;
  opacity: 0.8;
}

.ic-u::after {
  content: '';
  position: absolute;
  top: 18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 8rpx;
  border: 2rpx solid #fff;
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
}

.ic-svg {
  width: 36rpx;
  height: 36rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  opacity: 0.7;
}

.ic-key {
  width: 36rpx;
  height: 36rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  opacity: 0.5;
}

.ic-eye {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  opacity: 0.5;
}

.fi {
  flex: 1;
  height: 84rpx;
  font-size: 26rpx;
  color: #fff;
  background: transparent;
  border: none;
  padding: 0;
}

.ph {
  color: rgba(255, 255, 255, 0.55);
  font-size: 24rpx;
}

/* 选项行 */
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.ck-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ck {
  width: 22rpx;
  height: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.ck-on {
  background: transparent;
  border-color: transparent;
}

.ck-on::after {
  content: '\2713';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 18rpx;
  color: #1e6eff;
  font-weight: 700;
  line-height: 1;
}

.ck-t {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.55);
}

.fk {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.55);
}

/* 登录按钮 */
.btn {
  height: 84rpx;
  background: linear-gradient(135deg, #1e6eff 0%, #56a8ff 100%);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 6rpx 20rpx rgba(30, 110, 255, 0.35);
  -webkit-tap-highlight-color: transparent;
}

.btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.dim {
  opacity: 0.6;
  pointer-events: none;
}

.sp {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.plane {
  width: 0;
  height: 0;
  border-left: 12rpx solid #fff;
  border-top: 7rpx solid transparent;
  border-bottom: 7rpx solid transparent;
}

.bt {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 6rpx;
}

/* 分割线 - 绝对无bug版 */
.divider {
  position: relative;
  margin-top: 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
  height: 1px;
  line-height: 1px;
}

.divider::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.08);
}

.div-text {
  position: relative;
  z-index: 2;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.3);
  padding: 0 16rpx;
  background: #001552;
}

/* 其他登录方式 */
.methods {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-top: 22rpx;
}

.method {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.method-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.04);
}

.method-name {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 人脸 */
.m-face {
  width: 20rpx;
  height: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 10rpx;
  position: relative;
}

.m-face::after {
  content: '';
  position: absolute;
  width: 5rpx;
  height: 5rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 50%;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 指纹 */
.m-finger {
  width: 18rpx;
  height: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 9rpx;
  border-bottom-color: transparent;
}

/* 微信 */
.m-wechat {
  width: 20rpx;
  height: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 6rpx;
  position: relative;
}

.m-wechat::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 50%;
}

/* 协议 */
.agree {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-top: 16rpx;
}

.agree-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
}

.agree-text {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 弹窗 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal {
  width: 600rpx;
  background: rgba(12, 20, 40, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  overflow: hidden;
}

.mh {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.mt {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.mx {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 8rpx;
}

.mb {
  padding: 28rpx;
}

.mf {
  margin-bottom: 14rpx;
}

.mf:last-child {
  margin-bottom: 0;
}

.mft {
  display: flex;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.mbtn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  font-size: 26rpx;
}

.mc {
  color: rgba(255, 255, 255, 0.5);
  border-right: 1rpx solid rgba(255, 255, 255, 0.06);
}

.mo {
  color: #1e6eff;
  font-weight: 600;
}
