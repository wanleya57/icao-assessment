.phrases-page { padding: 24rpx; min-height: 100vh; box-sizing: border-box; }
.page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.page-title { font-size: 36rpx; font-weight: 700; color: #111; }
.add-btn { background: #111; color: #fff; padding: 10rpx 24rpx; border-radius: 8rpx; font-size: 24rpx; }

.cat-bar { white-space: nowrap; margin-bottom: 20rpx; }
.cat-item { display: inline-block; padding: 10rpx 24rpx; margin-right: 12rpx; border-radius: 8rpx; font-size: 24rpx; background: #f0f0f0; color: #666; }
.cat-item.active { background: #111; color: #fff; }

.add-form { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.form-item { margin-bottom: 20rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 8rpx; display: block; }
.form-input { background: #f5f5f5; border: 1rpx solid #e8e8e8; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; }
.picker-display { display: flex; justify-content: space-between; align-items: center; }
.picker-arrow { font-size: 32rpx; color: #ccc; }
.form-actions { display: flex; gap: 16rpx; }

.phrase-card { background: #fff; border-radius: 12rpx; padding: 20rpx 24rpx; margin-bottom: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.phrase-cat { font-size: 22rpx; color: #1a73e8; margin-bottom: 8rpx; }
.phrase-text { font-size: 28rpx; color: #333; line-height: 1.6; margin-bottom: 12rpx; }
.phrase-actions { display: flex; gap: 24rpx; align-items: center; }
.phrase-copy { font-size: 24rpx; color: #1a73e8; }
.phrase-del { font-size: 24rpx; color: #e53935; }
.phrase-default { font-size: 20rpx; color: #ccc; background: #f5f5f5; padding: 4rpx 12rpx; border-radius: 4rpx; }

.empty { padding: 120rpx 0; text-align: center; }
.empty-text { font-size: 28rpx; color: #ccc; }
