.ob-assess-page { display: flex; flex-direction: column; height: 100vh; background: #f5f5f5; }

.page-header { padding: 24rpx; background: #fff; border-bottom: 1rpx solid #eee; }
.page-title { font-size: 34rpx; font-weight: 600; color: #111; }
.page-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; line-height: 1.5; }
.page-progress { font-size: 24rpx; color: #1a73e8; margin-top: 8rpx; }

.ob-list { flex: 1; padding: 20rpx 24rpx; }

.ob-card { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.ob-header { display: flex; align-items: flex-start; gap: 12rpx; }
.ob-code { font-size: 24rpx; color: #1a73e8; font-weight: 600; min-width: 100rpx; }
.ob-name { font-size: 28rpx; color: #333; line-height: 1.5; flex: 1; }
.ob-name-en { font-size: 22rpx; color: #999; margin-top: 4rpx; margin-left: 112rpx; }

.level-buttons { display: flex; gap: 12rpx; margin-top: 16rpx; }
.level-btn { flex: 1; padding: 14rpx 0; text-align: center; font-size: 24rpx; border: 2rpx solid #e8e8e8; border-radius: 8rpx; background: #f9f9f9; color: #666; transition: all 0.15s; }
.level-btn:active { transform: scale(0.95); }

.ob-level-summary { margin-top: 12rpx; padding: 8rpx 12rpx; background: #f0f7ff; border-radius: 6rpx; }
.ob-summary-text { font-size: 22rpx; color: #1a73e8; }

.evidence-toggle { margin-top: 12rpx; }
.evidence-toggle-text { font-size: 22rpx; color: #1a73e8; }

.ob-evidence { margin-top: 12rpx; }
.evidence-input { width: 100%; min-height: 80rpx; background: #f9f9f9; border: 1rpx solid #eee; border-radius: 8rpx; padding: 16rpx; font-size: 26rpx; color: #333; box-sizing: border-box; }

.records-toggle { margin-top: 12rpx; }
.records-toggle-text { font-size: 22rpx; color: #1a73e8; }

.ob-records { margin-top: 12rpx; }
.ob-record-item { padding: 12rpx 0; border-top: 1rpx solid #f0f0f0; }
.ob-record-item:first-child { border-top: none; }
.ob-record-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.ob-record-level { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 4rpx; }
.ob-record-time { font-size: 20rpx; color: #bbb; flex: 1; }
.ob-record-delete { font-size: 20rpx; color: #e53935; padding: 4rpx 12rpx; border: 1rpx solid #e53935; border-radius: 4rpx; }
.ob-record-fb { display: flex; align-items: flex-start; gap: 8rpx; margin-top: 6rpx; }
.ob-record-label { font-size: 20rpx; color: #999; flex-shrink: 0; padding-top: 2rpx; }
.ob-record-text { font-size: 22rpx; color: #666; line-height: 1.5; }
.ob-record-text.professional { color: #333; }

.save-bar { padding: 20rpx 24rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); background: #fff; border-top: 1rpx solid #eee; }
.save-btn { background: #111; color: #fff; padding: 24rpx; border-radius: 12rpx; text-align: center; font-size: 30rpx; font-weight: 500; }
.save-btn:active { opacity: 0.8; }
.save-btn.saving { opacity: 0.5; }
