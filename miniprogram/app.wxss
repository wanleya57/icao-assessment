page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

.container { padding: 24rpx; min-height: 100vh; box-sizing: border-box; }
.card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.divider { height: 1rpx; background: #eee; margin: 20rpx 0; }
.btn-primary { background: #111; color: #fff; padding: 24rpx; border-radius: 12rpx; text-align: center; font-size: 30rpx; font-weight: 500; }
.btn-primary:active { opacity: 0.8; }
.btn-secondary { background: #f0f0f0; color: #333; padding: 24rpx; border-radius: 12rpx; text-align: center; font-size: 30rpx; }
.btn-danger { background: #e53935; color: #fff; padding: 24rpx; border-radius: 12rpx; text-align: center; font-size: 30rpx; }
.form-item { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 8rpx; }
.form-input { background: #f5f5f5; border: 1rpx solid #e8e8e8; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; }
